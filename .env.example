# =============================================================================
# Telegram Bot Configuration
# =============================================================================

# Telegram Bot API token (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# URL FastAPI бэкенда (FS-4)
BACKEND_URL=http://localhost:8000

# =============================================================================
# Backend Configuration
# =============================================================================

# URL Redis (FS-4)
REDIS_URL=redis://localhost:6379

# OpenRouter API key для AI-генерации спрайтов: GPT-4o Vision + DALL-E 3 (FS-3)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# GitHub Personal Access Token для публикации игр (FS-4)
GITHUB_TOKEN=your_github_personal_access_token_here

# GitHub репозиторий для публикации (owner/repo)
GITHUB_REPO=username/repo-name

# Базовый URL GitHub Pages для сформированных game_url
GAME_BASE_URL=https://username.github.io/repo-name

# =============================================================================
# Запуск локально:
# 1. cp .env.example .env  — заполни токены
# 2. docker-compose up --build
# Или без Docker:
# 3. redis-server &
# 4. python -m uvicorn backend.main:app --reload &
# 5. python -m bot.main
# =============================================================================
